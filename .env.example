# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: the site's public URL, used for link-preview (Open Graph) tags.
# On Vercel this is auto-detected; set it explicitly once a custom domain exists.
NEXT_PUBLIC_SITE_URL=
